 "html": "<style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: Arial, sans-serif; font-size: 11px; }\n    .invoice-container { max-width: 210mm; margin: 0 auto; padding: 20px; }\n    .header { display: flex; justify-content: space-between; align-items: start; margin-bottom: 20px; border-bottom: 3px solid #D2691E; padding-bottom: 15px; }\n    .header-left { display: flex; align-items: center; gap: 15px; }\n    .logo { width: 120px; height: auto; }\n    .company-info { font-size: 10px; line-height: 1.4; }\n    .company-name { font-size: 13px; font-weight: bold; color: #333; margin-bottom: 3px; }\n    .header-right { text-align: right; }\n    .invoice-title { font-size: 22px; font-weight: bold; color: #0066CC; margin-bottom: 5px; }\n    .invoice-meta { font-size: 10px; line-height: 1.6; }\n    .invoice-to { background: #f5f5f5; padding: 12px; margin-bottom: 20px; border-left: 4px solid #0066CC; }\n    .invoice-to strong { font-size: 11px; }\n    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }\n    .items-table thead { background: #0066CC; color: white; }\n    .items-table th { padding: 12px; text-align: left; font-weight: bold; font-size: 11px; }\n    .items-table td { padding: 10px; border-bottom: 1px solid #ddd; vertical-align: top; }\n    .items-table .desc-cell { width: 50%; }\n    .total-row { background: #0066CC; color: white; font-weight: bold; font-size: 14px; }\n    .payment-section { display: flex; gap: 20px; margin-top: 20px; }\n    .payment-details { flex: 1; font-size: 10px; line-height: 1.8; }\n    .payment-details h4 { margin-bottom: 10px; font-size: 12px; }\n    .terms { margin-top: 20px; }\n    .terms h4 { font-size: 12px; margin-bottom: 8px; }\n    .terms ol { padding-left: 20px; font-size: 10px; line-height: 1.8; }\n    .footer-banner { background: #0066CC; color: white; text-align: center; padding: 10px; margin-top: 30px; display: flex; justify-content: center; align-items: center; gap: 30px; }\n    .footer-banner img { height: 40px; }\n    .text-right { text-align: right; }\n    .text-center { text-align: center; }\n</style>\n\n<div class=\"invoice-container\">\n    <!-- HEADER -->\n    <div class=\"header\">\n        <div class=\"header-left\">\n            <img src=\"/files/royal-logo.png\" class=\"logo\" alt=\"Royal Logo\">\n            <div class=\"company-info\">\n                <div class=\"company-name\">CMHL ROYAL LOGISTICS & SUPPLIES<br>COMPANY LIMITED</div>\n                P.O.BOX 22663 DAR ES SALAAM<br>\n                +255 718 072 123 | +255 656 233 020<br>\n                sales@royal.co.tz\n            </div>\n        </div>\n        <div class=\"header-right\">\n            <div class=\"invoice-title\">COMMERCIAL<br>INVOICE</div>\n            <div class=\"invoice-meta\">\n                <strong>TIN NO:</strong> 126-927-169<br>\n                <strong>Date:</strong> {{ doc.get_formatted(\"posting_date\") }}<br>\n                <strong>Payment Terms:</strong> {{ doc.payment_terms_template or \"Cash Deposit\" }}<br>\n                <strong>Due Date:</strong> {{ doc.get_formatted(\"due_date\") }}<br>\n                <strong>INVOICE NO:</strong> {{ doc.name }}\n            </div>\n        </div>\n    </div>\n\n    <!-- INVOICE TO -->\n    <div class=\"invoice-to\">\n        <strong>INVOICE TO:</strong><br>\n        <strong>{{ doc.customer_name }}</strong><br>\n        {{ doc.customer_address or \"DAR ES SALAAM\" }}<br>\n        {% if doc.contact_mobile %}{{ doc.contact_mobile }}<br>{% endif %}\n        {% if doc.contact_email %}{{ doc.contact_email }}{% endif %}\n    </div>\n\n    <!-- ITEMS TABLE -->\n    <table class=\"items-table\">\n        <thead>\n            <tr>\n                <th class=\"desc-cell\">DESCRIPTION</th>\n                <th class=\"text-center\">QTY</th>\n                <th>TYPE</th>\n                <th class=\"text-right\">PRICE</th>\n                <th class=\"text-right\">AMOUNT</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td class=\"desc-cell\">\n                    <strong>{{ item.item_name }}</strong><br>\n                    <div style=\"font-size: 10px; color: #555; margin-top: 5px;\">\n                        {{ item.description | replace(\"\\n\", \"<br>\") if item.description else \"\" }}\n                    </div>\n                </td>\n                <td class=\"text-center\">{{ item.qty }}</td>\n                <td>{{ item.uom or \"CIF\" }}</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(item.rate) }}</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(item.amount) }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n        <tfoot>\n            <tr class=\"total-row\">\n                <td colspan=\"4\" class=\"text-right\" style=\"padding-right: 20px;\">TOTAL</td>\n                <td class=\"text-right\"><strong>{{ \"{:,.0f}\".format(doc.grand_total) }}</strong></td>\n            </tr>\n        </tfoot>\n    </table>\n\n    <!-- PAYMENT DETAILS & TERMS -->\n    <div class=\"payment-section\">\n        <div class=\"payment-details\">\n            <h4>PAYMENT DETAILS</h4>\n            <strong>Bank Name:</strong> ABSA BANK TANZANIA LTD<br>\n            <strong>Branch:</strong> ALPHA HOUSE<br>\n            <strong>Swift code:</strong> BARCTZTZ<br>\n            <strong>A/C Number:</strong> 0216003209<br>\n            <strong>A/C Name:</strong> CMHL ROYAL LOG AND SUPPLIES COMPANY LIMITED<br><br>\n            \n            <strong>BANK:</strong> CRDB BANK PLC<br>\n            <strong>ACCOUNT NAME:</strong> CMHL ROYAL LOGISTICS AND SUPPLIES COMPANY LIMITED<br>\n            <strong>ACCOUNT NUMBER:</strong> 015C001L5JA00<br>\n            <strong>BRANCH:</strong> DAR VILLAGE\n        </div>\n    </div>\n\n    <div class=\"terms\">\n        <h4>TERMS & CONDITIONS</h4>\n        <ol>\n            <li>Invoice valid for 3 days</li>\n            <li>The order is valid as per request</li>\n            <li>Any bank charges shall be borne and paid by the client</li>\n        </ol>\n    </div>\n\n    <!-- FOOTER -->\n    <div class=\"footer-banner\">\n        <span>\ud83c\udf10 www.royal.co.tz</span>\n        <span>\ud83d\udcd8 royal_logistics</span>\n        <span>\ud83d\udcf7 royal_logistics</span>\n        <img src=\"/files/royal-motors-logo.png\" alt=\"Royal Motors\" style=\"height: 50px;\">\n    </div>\n</div>",
