 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n    .print-format { font-family: Arial, sans-serif; font-size: 10px; }\n    .header-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }\n    .header-logo { width: 150px; }\n    .invoice-title { font-size: 24px; font-weight: bold; color: #005A9C; margin: 0; }\n    .invoice-to { background-color: #f2f2f2; padding: 10px; margin-bottom: 20px; border-left: 4px solid #005A9C; }\n    .items-table thead { background-color: #005A9C; color: white; }\n</style>\n<div class=\"print-format\">\n    <div style=\"border-bottom: 2px solid #D9853B; padding-bottom: 10px; margin-bottom: 20px;\">\n        <table class=\"header-table\">\n            <tr>\n                <td rowspan=\"2\" style=\"width: 20%;\"><img src=\"/files/royal-logo.png\" class=\"header-logo\" style=\"max-width: 150px;\"></td>\n                <td style=\"text-align: left; vertical-align: top; padding-left: 15px;\">\n                    <h3 style=\"margin: 0; font-size: 14px; color: #003366;\">CMHL ROYAL LOGISTICS & SUPPLIES</h3>\n                    <p style=\"margin: 2px 0;\">P.O.BOX 22663 DAR ES SALAAM</p>\n                    <p style=\"margin: 2px 0;\">+255 718 072 123 | +255 656 233 020</p>\n                    <p style=\"margin: 2px 0;\">sales@royal.co.tz</p>\n                </td>\n                <td style=\"text-align: right; vertical-align: top;\">\n                    <p class=\"invoice-title\">SALES INVOICE</p>\n                    <p><strong>TIN NO:</strong> 126-927-169</p>\n                    <p><strong>INVOICE NO:</strong> {{ doc.name }}</p>\n                    <p><strong>Date:</strong> {{ doc.get_formatted(\"posting_date\") }}</p>\n                    <p><strong>Due Date:</strong> {{ doc.get_formatted(\"due_date\") }}</p>\n                </td>\n            </tr>\n        </table>\n    </div>\n    \n    <div class=\"invoice-to\">\n        <strong>INVOICE TO:</strong><br>\n        <strong>{{ doc.customer_name }}</strong><br>\n        {{ doc.address_display or \"\" }}<br>\n        TIN: {{ doc.tax_id or \"\" }}\n    </div>\n\n    <table class=\"table table-bordered items-table\" style=\"width: 100%;\">\n        <thead>\n            <tr>\n                <th>DESCRIPTION</th>\n                <th style=\"text-align: center;\">QTY</th>\n                <th style=\"text-align: right;\">PRICE</th>\n                <th style=\"text-align: right;\">AMOUNT</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td>\n                    <strong>{{ item.item_name }}</strong><br>\n                    <div style=\"padding-left: 15px; font-size: 9px; color: #555;\">\n                        {{ item.description | replace(\"\\n\", \"<br>\") if item.description }}\n                    </div>\n                </td>\n                <td style=\"text-align: center;\">{{ item.qty }}</td>\n                <td style=\"text-align: right;\">{{ frappe.utils.fmt_money(item.rate, currency=doc.currency) }}</td>\n                <td style=\"text-align: right;\">{{ frappe.utils.fmt_money(item.amount, currency=doc.currency) }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n    <table style=\"width: 100%; margin-top: 10px;\">\n        <tr>\n            <td style=\"width: 60%;\">\n                <h4>PAYMENT DETAILS</h4>\n                <p><strong>Bank:</strong> ABSA BANK TANZANIA LTD | <strong>A/C:</strong> 0216003209</p>\n                <p><strong>Bank:</strong> CRDB BANK PLC | <strong>A/C:</strong> 015C001L5JA00</p>\n                <p><strong>A/C Name:</strong> CMHL ROYAL LOG AND SUPPLIES COMPANY LIMITED</p>\n            </td>\n            <td style=\"width: 40%; vertical-align: top;\">\n                <table class=\"table table-bordered\">\n                    <tr style=\"background-color: #005A9C; color: white;\">\n                        <td><strong>TOTAL (TZS)</strong></td>\n                        <td style=\"text-align: right;\"><strong>{{ frappe.utils.fmt_money(doc.grand_total, currency=doc.currency) }}</strong></td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n    \n    <div style=\"margin-top: 20px;\">\n        <div style=\"text-align: center; background-color: #005A9C; color: white; padding: 5px;\">\n            www.royal.co.tz | \"Legacy of excellence dedicated to quality\"\n        </div>\n    </div>\n</div>",
